{
  "name": "cascade",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Real-time event analytics platform",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "services/*",
    "libs/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc --build",
    "test": "vitest",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@eslint/js": "9.9.0",
    "eslint": "9.9.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.4",
    "lint-staged": "15.5.2",
    "patch-package": "8.0.0",
    "prettier": "3.3.3",
    "typescript": "5.5.4",
    "typescript-eslint": "8.1.0",
    "vitest": "4.1.7"
  }
}
