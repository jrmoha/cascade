# Copy to .env and adjust values for your local environment.
# All defaults below match the docker-compose.yml setup.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cascade
POSTGRES_USER=cascade
POSTGRES_PASSWORD=cascade

# Kafka — use localhost:9092 from host, kafka:29092 from inside Docker
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cassandra
# Note: with the default SimpleSnitch the datacenter is always "datacenter1"
# (the CASSANDRA_DC env is only honored by Gossiping/PropertyFile snitches).
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_LOCAL_DC=datacenter1
