# Query API — copy to .env (or inject these as container env). Every variable
# below is validated by a Zod schema at boot; a missing/invalid value fails fast.

# HTTP port the Query API binds (health + GET /query). Optional; defaults to 3002.
PORT=3002

# Cassandra (read store). All REQUIRED — no defaults.
# Host tooling: localhost · inside docker-compose: cassandra
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
# With Cassandra's default SimpleSnitch the datacenter is always "datacenter1".
CASSANDRA_LOCAL_DC=datacenter1
