# Query API — copy to .env (or inject these as container env). Every variable
# below is validated by a Zod schema at boot; a missing/invalid value fails fast.

# HTTP port the Query API binds (health + GET /query). Optional; defaults to 3002.
PORT=3002

# Cassandra (raw-retrieval read store). All REQUIRED — no defaults.
# Host tooling: localhost · inside docker-compose: cassandra
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
# With Cassandra's default SimpleSnitch the datacenter is always "datacenter1".
CASSANDRA_LOCAL_DC=datacenter1

# Redis (leaderboard read model — the Aggregator writes it, KAN-34). REQUIRED.
# Host tooling: localhost · inside docker-compose: redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Postgres (funnel & retention summaries — the Aggregator writes them, KAN-35).
# REQUIRED. Read-only here; the Aggregator owns the schema/migrations.
# Host tooling: localhost · inside docker-compose: postgres
DATABASE_URL=postgresql://cascade:cascade@localhost:5432/cascade
