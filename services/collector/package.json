{
  "name": "@cascade/collector",
  "version": "0.0.1",
  "private": true,
  "description": "Cascade Collector — accepts events over HTTP and produces them to Kafka",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cascade/contracts": "0.0.1",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/microservices": "10.4.4",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/terminus": "10.2.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "kafkajs": "2.2.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.4",
    "@swc/core": "1.7.26",
    "@testcontainers/kafka": "10.13.2",
    "@types/express": "4.17.21",
    "@types/node": "22.19.19",
    "@types/supertest": "6.0.2",
    "supertest": "7.0.0",
    "testcontainers": "10.13.2",
    "ts-node-dev": "2.0.0",
    "unplugin-swc": "1.5.1"
  }
}
