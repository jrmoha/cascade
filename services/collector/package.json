{
  "name": "@cascade/collector",
  "version": "0.0.1",
  "private": true,
  "description": "Cascade Collector — accepts events over HTTP and produces them to Kafka",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --exit-child --transpile-only src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cascade/contracts": "0.0.1",
    "@grpc/grpc-js": "1.12.2",
    "@grpc/proto-loader": "0.7.13",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/terminus": "^11.1.1",
    "ajv": "8.17.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.4.1",
    "kafkajs": "2.2.4",
    "opossum": "10.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "1.7.26",
    "@testcontainers/kafka": "^12.0.1",
    "@types/express": "4.17.21",
    "@types/node": "22.19.19",
    "@types/opossum": "8.1.9",
    "@types/supertest": "6.0.2",
    "supertest": "7.0.0",
    "testcontainers": "^12.0.1",
    "ts-node-dev": "2.0.0",
    "unplugin-swc": "1.5.1"
  }
}
