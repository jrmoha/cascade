# Collector — copy to .env (or inject these as container env). Every variable
# below is validated by a Zod schema at boot; a missing/invalid value fails fast.

# HTTP port the Collector binds (health + POST /collect). Optional; defaults to 3001.
PORT=3001

# Kafka brokers (comma-separated). REQUIRED — no default.
# Host tooling: localhost:9092 · inside docker-compose: kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
