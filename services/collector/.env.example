# Collector — copy to .env (or inject these as container env). Every variable
# below is validated by a Zod schema at boot; a missing/invalid value fails fast.

# HTTP port the Collector binds (health + POST /collect). Optional; defaults to 3001.
PORT=3001

# Kafka brokers (comma-separated). REQUIRED — no default.
# Host tooling: localhost:9092,localhost:9094,localhost:9095
# inside docker-compose: kafka-1:29092,kafka-2:29092,kafka-3:29092 (3-broker cluster, KAN-40)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis — backs the ingest hot-path cache (apiKey→projectId + per-project event
# schemas). REQUIRED — no default. Host tooling: localhost / 6379 ·
# inside docker-compose: redis / 6379.
REDIS_HOST=localhost
REDIS_PORT=6379

# Project/Schema gRPC endpoint for key verification + schema fetch (KAN-29
# contract). REQUIRED — no default. Host tooling: 127.0.0.1:50051 ·
# inside docker-compose: project-schema:50051
PROJECT_SCHEMA_GRPC_URL=127.0.0.1:50051

# TTL (seconds) for cached key/schema lookups. Optional; defaults to 30.
# Short so key revocations and schema edits propagate quickly. See ADR-0013.
PROJECT_SCHEMA_CACHE_TTL_SECONDS=30

# --- Ingestion resilience (KAN-42, ADR-0021). All optional (tuning knobs). ---

# Per-API-key rate limit (Redis token bucket): sustained tokens/sec + burst
# (bucket capacity). A key over budget gets 429 with Retry-After.
RATE_LIMIT_REFILL_PER_SEC=50
RATE_LIMIT_BURST=100

# Backpressure + produce retry. MAX_INFLIGHT caps concurrent Kafka produces
# (beyond it → 503, no unbounded buffering). TIMEOUT_MS bounds one produce.
# Transient failures retry MAX_ATTEMPTS times with backoff RETRY_BASE_MS*2^(n-1);
# exhaustion → 503 (client retries; nothing is silently dropped).
PRODUCE_MAX_INFLIGHT=500
PRODUCE_TIMEOUT_MS=5000
PRODUCE_MAX_ATTEMPTS=3
PRODUCE_RETRY_BASE_MS=100

# Circuit breaker (opossum) around the Project/Schema gRPC calls. Opens when the
# error rate exceeds ERROR_PCT over at least VOLUME calls, stays open RESET_MS
# before a trial call. Open → fast fail-closed/cached (ADR-0013); NOT_FOUND
# (unregistered schema) is data, never trips the breaker.
PROJECT_SCHEMA_BREAKER_ERROR_PCT=50
PROJECT_SCHEMA_BREAKER_RESET_MS=10000
PROJECT_SCHEMA_BREAKER_VOLUME=5
