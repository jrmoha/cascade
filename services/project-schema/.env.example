# Project/Schema service — copy to .env (or inject these as container env).
# PORT is the only var with a conventional default; DATABASE_URL is required
# (no fallback) and fails fast at boot if missing/invalid.
PORT=3004
# Prisma reads DATABASE_URL directly. Use the container service name (postgres)
# for service-to-service; use localhost:5432 from the host.
DATABASE_URL=postgresql://cascade:cascade@localhost:5432/cascade
