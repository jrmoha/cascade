// Prisma owns the relational schema for the Project/Schema service (KAN-28).
// This is the single source of truth for the DB; the wire/API contracts live
// separately as Zod schemas in @cascade/contracts (see ADR-0011). Schema changes
// go through versioned migrations under prisma/migrations/ (applied on service
// boot and via `npm run migrate` — never `synchronize`/`db push` in prod).

generator client {
  provider = "prisma-client-js"
  // Prisma 7 dropped the Rust query-engine binary: queries run through the WASM
  // query compiler + a JS driver adapter (`@prisma/adapter-pg`, wired up in
  // DatabaseService). There is no per-platform engine to embed, so `binaryTargets`
  // is gone — the generated client is portable across local dev (macOS) and the
  // node:22-slim runtime image alike. See ADR-0011.
}

datasource db {
  // Prisma 7: the connection URL no longer lives here. Migrate reads it from
  // `prisma.config.ts`; the runtime client gets it from the pg driver adapter
  // in DatabaseService. See ADR-0011.
  provider = "postgresql"
}

/// A registered project (tenant). Owns its API keys and event schemas.
model Project {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime      @default(now()) @map("created_at")
  apiKeys   ApiKey[]
  schemas   EventSchema[]

  @@map("projects")
}

/// An API key. Only the argon2 `hash` is stored — never the plaintext secret.
/// `prefix` is the non-secret, unique lookup id used to find the row on verify
/// (one indexed lookup, then argon2.verify of the secret half).
model ApiKey {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  prefix    String    @unique
  hash      String
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("api_keys")
}

/// A per-project event schema, stored as a JSON Schema document in jsonb so the
/// Collector can fetch it and validate events dynamically (KAN-30). Unique per
/// (projectId, eventType) so it is retrievable by that pair.
model EventSchema {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  eventType  String   @map("event_type")
  jsonSchema Json     @map("json_schema") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, eventType])
  @@map("event_schemas")
}
