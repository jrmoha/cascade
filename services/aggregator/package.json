{
  "name": "@cascade/aggregator",
  "version": "0.0.1",
  "private": true,
  "description": "Cascade Aggregator — consumes raw-events and derives read models (counters/leaderboards/funnels/retention). Phase 1: consumer skeleton (KAN-31, ADR-0015).",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "node ../../node_modules/typescript-7/bin/tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --exit-child --transpile-only src/main.ts",
    "migrate": "node dist/cassandra/migrate.js",
    "migrate:dev": "ts-node-dev --transpile-only src/cassandra/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cascade/contracts": "0.0.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/terminus": "^11.1.1",
    "cassandra-driver": "4.9.0",
    "ioredis": "5.4.1",
    "kafkajs": "2.2.4",
    "pg": "^8.13.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "1.7.26",
    "@testcontainers/kafka": "^12.0.1",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "22.19.19",
    "@types/pg": "^8.11.10",
    "testcontainers": "^12.0.1",
    "ts-node-dev": "2.0.0",
    "unplugin-swc": "1.5.1"
  }
}
