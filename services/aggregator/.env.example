# Aggregator — copy to .env (or inject these as container env). Every variable
# below is validated by a Zod schema at boot; a missing/invalid value fails
# fast. The Aggregator is a hybrid app: a Kafka consumer (second, independent
# consumer of `raw-events`) plus a small HTTP server for the health/readiness
# probes. Phase 1 skeleton (KAN-31, ADR-0015): it consumes and DLQs, but derives
# no read models yet.

# HTTP port for the health/readiness probes. Optional; defaults to 3005.
PORT=3005

# Kafka brokers (comma-separated). REQUIRED — no default.
# Host tooling: localhost:9092 · inside docker-compose: kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Cassandra (time-series counter read models). All REQUIRED — no defaults.
# Host tooling: localhost · inside docker-compose: cassandra
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
# With Cassandra's default SimpleSnitch the datacenter is always "datacenter1".
CASSANDRA_LOCAL_DC=datacenter1

# Redis (leaderboard sorted sets + dedup store). All REQUIRED — no defaults.
# Host tooling: localhost · inside docker-compose: redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Postgres (funnel/retention summary read models). REQUIRED — no default.
# The Aggregator owns its own tables here (raw `pg`, separate from the
# Project/Schema service's Prisma-managed tables — see ADR-0011/ADR-0015).
# Host tooling: localhost:5432 · inside docker-compose: postgres:5432
DATABASE_URL=postgresql://cascade:cascade@localhost:5432/cascade
