# Ingestion-Processor — copy to .env (or inject these as container env). Every
# variable below is validated by a Zod schema at boot; a missing/invalid value
# fails fast. The processor is a hybrid app: a Kafka consumer plus a small HTTP
# server that serves the health/readiness probes.

# HTTP port for the health/readiness probes. Optional; defaults to 3003.
PORT=3003

# Kafka brokers (comma-separated). REQUIRED — no default.
# Host tooling: localhost:9092 · inside docker-compose: kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Cassandra (write store). All REQUIRED — no defaults.
# Host tooling: localhost · inside docker-compose: cassandra
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
# With Cassandra's default SimpleSnitch the datacenter is always "datacenter1".
CASSANDRA_LOCAL_DC=datacenter1
