{
  "name": "@cascade/ingestion-processor",
  "version": "0.0.1",
  "private": true,
  "description": "Cascade Ingestion-Processor — consumes raw-events from Kafka and writes them to Cassandra",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "migrate": "node dist/cassandra/migrate.js",
    "migrate:dev": "ts-node-dev --transpile-only src/cassandra/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cascade/contracts": "0.0.1",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/microservices": "10.4.4",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/terminus": "10.2.3",
    "cassandra-driver": "4.9.0",
    "kafkajs": "2.2.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.4",
    "@swc/core": "1.7.26",
    "@testcontainers/kafka": "10.13.2",
    "@types/node": "22.19.19",
    "testcontainers": "10.13.2",
    "ts-node-dev": "2.0.0",
    "unplugin-swc": "1.5.1"
  }
}
