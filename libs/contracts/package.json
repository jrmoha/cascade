{
  "name": "@cascade/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Shared event contracts and topic definitions for Cascade services",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "proto"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript-7/bin/tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "proto:gen": "mkdir -p src/generated && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=../../node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated --ts_proto_opt=onlyTypes=true,esModuleInterop=true,snakeToCamel=true --proto_path=proto proto/project_schema.proto",
    "proto:check": "npm run proto:gen && git diff --exit-code -- src/generated",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "grpc-tools": "^1.12.4",
    "ts-proto": "^2.6.1",
    "zod-to-json-schema": "^3.23.5"
  }
}
